# ─── Contact form backend ────────────────────────────────────────────────
# Copy this file to .env.local and fill in your secrets.
# Set the same vars in Vercel → Project → Settings → Environment Variables.

# Notion integration (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID of the parent page where the "Solicitudes" DB will be created.
# Only needed for the one-shot `npm run setup-notion` script.
# Create a Notion page (e.g. "Kobra CRM"), share it with your integration
# (··· menu → Add connections → your integration), then copy its ID from the URL.
NOTION_PARENT_PAGE_ID=00000000000000000000000000000000

# ID of the Solicitudes database (printed by `npm run setup-notion`).
NOTION_DATABASE_ID=00000000000000000000000000000000

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email sender. Must be on a domain you've verified in Resend.
# Use "onboarding@resend.dev" while you verify kobra-automation.com.
CONTACT_FROM_EMAIL="Kobra AI <noreply@kobra-automation.com>"

# Where contact-form notifications are delivered.
CONTACT_TO_EMAIL=kobra.automation.ia@gmail.com
