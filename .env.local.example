# ── Claude API ──────────────────────────────────────────────────
# Crea tu cuenta en console.anthropic.com y genera una API key.
# Tu plan Pro de Claude.ai NO incluye acceso a la API.
# El plan de pago por uso cuesta ~$0.003 por conversación corta.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Contacto ────────────────────────────────────────────────────
# Número de WhatsApp Business con prefijo de país, sin espacios ni +
# Ejemplo España: 34612345678
NEXT_PUBLIC_WHATSAPP_NUMBER=34XXXXXXXXX

# Email donde llegará el formulario de contacto
NEXT_PUBLIC_CONTACT_EMAIL=hola@kobra.ai

# ── Calendly ────────────────────────────────────────────────────
# Crea tu cuenta gratis en calendly.com y pega tu URL de evento
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/tu-usuario/demo-kobra
